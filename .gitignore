## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
ARM/
ARM64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio cache/options
.vs/
.vscode/

# Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# .NET Core / ASP.NET
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# IIS Express
.vs/config/applicationhost.config

# Azure local settings (IMPORTANT - secrets)
local.settings.json

# Publish output
publish/
*.pubxml
*.publishproj

# Web deploy
*.azurePubxml

# Rider / Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# SQL Server
*.mdf
*.ldf

# Entity Framework
*.jfm

# NCrunch
_NCrunch_*
.*crunch*.local.xml

# BenchmarkDotNet
BenchmarkDotNet.Artifacts/

# StyleCop
StyleCopReport.xml

# DotCover
*.dotCover

# Logs
*.log

# Temp files
*.tmp
*.temp

# Node (if frontend assets exist)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
Thumbs.db
Desktop.ini
.DS_Store

# Azure Functions
bin/
obj/

# Selenium / browser drivers
chromedriver.exe
geckodriver.exe
msedgedriver.exe